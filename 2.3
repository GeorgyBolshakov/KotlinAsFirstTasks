fun timeForHalfWay(t1: Double, v1: Double, t2: Double, v2: Double, t3: Double, v3: Double): Double {
    val r1 = t1 * v1
    val r2 = t2 * v2
    val r = (r1 + r2 + t3 * v3) / 2
    return when {
        r < r1 -> r / v1
        r in r1..(r1 + r2) -> t1 + (r - r1) / v2
        else -> t1 + t2 + (r - r1 - r2) / v3
    }
}
fun main() {
    println(timeForHalfWay(1.0, 5.0, 2.0, 4.0, 3.0, 3.0))
    println(timeForHalfWay(4.0, 3.0, 1.0, 4.0, 1.0, 6.0))
    println(timeForHalfWay(3.0, 0.0, 1.0, 6.0, 2.0, 5.0))
}
